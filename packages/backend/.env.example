# Testing Configuration
PARALLEL_WORKERS=4
TEST_TIMEOUT=30000
GLOBAL_TIMEOUT=600000
RETRY_FAILED_TESTS=2
E2E_BROWSER=chromium
E2E_HEADLESS=true
E2E_SLOWMO=0

# Coverage Configuration
COVERAGE_THRESHOLD_LINES=70
COVERAGE_THRESHOLD_FUNCTIONS=70
COVERAGE_THRESHOLD_BRANCHES=60
COVERAGE_THRESHOLD_STATEMENTS=70
COVERAGE_REPORT_DIR=./coverage

# AI Test Generation
TEST_GEN_MODEL=gpt-4
MIN_TEST_QUALITY=0.7

# Test Scheduling
UNIT_TEST_SCHEDULE="0 0 * * *"
E2E_TEST_SCHEDULE="0 2 * * 0"
LOAD_TEST_SCHEDULE="0 3 * * 0"

# Load Testing
LOAD_WARMUP=100
LOAD_USERS=100
LOAD_RAMP_UP=30
LOAD_SUSTAIN=300
LOAD_RAMP_DOWN=30
SPIKE_BASE_USERS=50
SPIKE_PEAK_USERS=500
SPIKE_RAMP_UP=10
SOAK_USERS=50
SOAK_DURATION_HOURS=2
WS_LOAD_CONNECTIONS=100
WS_LOAD_MSG_PER_SEC=10

# Performance Thresholds
THRESHOLD_P50=200
THRESHOLD_P95=500
THRESHOLD_P99=1000
THRESHOLD_ERROR_RATE=0.01

# Bug Tracking
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...